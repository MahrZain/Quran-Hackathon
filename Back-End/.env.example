# ASAR Engine — Environment Template
# Copy this file to '.env' and fill in your secrets.
# DOCUMENTATION: See DOCUMENTATION.md for details on each variable.

# --- SECURITY ---
JWT_SECRET_KEY=generate-a-32-character-random-string-here
JWT_ALGORITHM=HS256

# --- QURAN FOUNDATION OAUTH ---
# Register the EXACT value of QURAN_OAUTH_REDIRECT_URI in the Foundation Console.
# Default canonical path: http://127.0.0.1:8000/api/v1/auth/callback
QURAN_OAUTH_CLIENT_ID=your-client-id-here
QURAN_OAUTH_CLIENT_SECRET=your-client-secret-here
QURAN_OAUTH_TOKEN_URL=https://prelive-oauth2.quran.foundation/oauth2/token
QURAN_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/callback
QURAN_USER_API_BASE_URL=https://apis-prelive.quran.foundation

# --- FRONTEND INTEGRATION ---
# Where should the backend redirect the browser AFTER a successful login?
FRONTEND_AFTER_OAUTH_URL=http://localhost:5173

# --- AI (LONGCAT / OPENAI COMPATIBLE) ---
LONGCAT_API_KEY=your-api-key-here
LONGCAT_BASE_URL=https://api.longcat.chat/openai/v1

# --- PERSISTENCE ---
# Use sqlite:///./asar.db for local; absolute path recommended for production.
DATABASE_URL=sqlite:///./asar.db
ENABLE_DEMO_LOGIN=true
CORS_ORIGINS=http://localhost:5173,https://your-domain.com
