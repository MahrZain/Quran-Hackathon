# Rename to `.env.production` before `npm run build` if you bundle env into the SPA.
# Same-origin deploy (SPA + API on https://fnwholesale.pk): you can omit these — the app defaults to window.location.origin/api/v1.

VITE_API_BASE_URL=https://fnwholesale.pk/api/v1
VITE_ASAR_ENGINE_ORIGIN=https://fnwholesale.pk
