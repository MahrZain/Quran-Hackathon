# Optional. If unset: `npm run dev` uses Vite proxy → http://127.0.0.1:8000 (see vite.config.ts).
# Production / preview: set explicitly. Prefer 127.0.0.1 over localhost if you see connection errors.
# VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1
# VITE_API_BASE_URL=http://127.0.0.1:8001/api/v1

# OAuth “Continue with Quran.com”: must match Back-End QURAN_OAUTH_REDIRECT_URI host (default dev: 127.0.0.1:8000).
# VITE_ASAR_ENGINE_ORIGIN=http://127.0.0.1:8000
#
# Production (fnwholesale.pk) — engine origin = public base URL of the Back-End (where /api/v1/auth/* lives):
# VITE_API_BASE_URL=https://api.fnwholesale.pk/api/v1
# VITE_ASAR_ENGINE_ORIGIN=https://api.fnwholesale.pk
# If the API is served from the same host as the SPA under /api/v1, use https://fnwholesale.pk for both.

# Optional overrides. "Try demo" uses POST /api/v1/auth/demo; Back-End demo user is configured in Back-End/.env.
# VITE_DEMO_LOGIN_EMAIL=demo@asar.local
# VITE_DEMO_LOGIN_PASSWORD=AsarJudge2026!
