# Copy to `.env` for local dev (gitignored). See also `.env.production.example` for `npm run build`.

# --- Local development (matches Back-End QURAN_OAUTH_REDIRECT_URI on 127.0.0.1:8000) ---
VITE_ASAR_ENGINE_ORIGIN=http://127.0.0.1:8000
# Optional; if unset, dev uses same-origin `/api/v1` via Vite proxy (vite.config.ts).
# VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# --- Production: same host as public API (OAuth + XHR) ---
# VITE_API_BASE_URL=https://fnwholesale.pk/api/v1
# VITE_ASAR_ENGINE_ORIGIN=https://fnwholesale.pk
#
# If API is on another subdomain, set both explicitly and set Back-End CORS_ORIGINS to the SPA origin.

# Optional demo overrides (Back-End demo user must exist)
# VITE_DEMO_LOGIN_EMAIL=demo@asar.local
# VITE_DEMO_LOGIN_PASSWORD=AsarJudge2026!

# --- Verse bookmarks (Back-End) ---
# Logged-in users: GET/POST/DELETE /api/v1/bookmarks persist to ASAR DB.
# Optional sync to Quran Foundation requires QURAN_OAUTH_AUTHORIZE_SCOPES to include `bookmark`
# and a user session with Quran.com OAuth tokens. Override URL if needed:
# QURAN_BOOKMARKS_URL=https://apis-prelive.quran.foundation/auth/v1/bookmarks
