# Local secrets — never commit (use .env.example as a template only)
.env
.env.*
!.env.example
!**/.env.example

# Back-End
Back-End/venv/
Back-End/__pycache__/
Back-End/**/__pycache__/
Back-End/.pytest_cache/
Back-End/asar.db
Back-End/logs/
Back-End/.env
Back-End/.env.*

# Front-End (extra; Front-End/.gitignore also applies when that folder is root)
Front-End/.env
Front-End/.env.*
!Front-End/.env.example
!Front-End/.env.production.example
